# ===========================================
# Zephyr Bridge Stack - Orchestration Config
# ===========================================
# This is the MASTER configuration file.
# Copy to .env: cp .env.example .env
#
# IMPORTANT: Update ROOT below to match your setup!
#
# Run ./scripts/sync-env.sh to generate repo-specific .env files
# from this master config.

# ===========================================
# Root Path (REQUIRED - update this!)
# ===========================================
# Parent directory containing all bridge repos (zephyr-bridge, zephyr-bridge-engine, etc.)
ROOT=/path/to/your/dev/folder

# ===========================================
# PATH Configuration (ensure node/pnpm available)
# ===========================================
# Overmind processes need node/pnpm in PATH. Update these paths for your system.
PATH=/home/youruser/.nvm/versions/node/v22.x.x/bin:/home/youruser/.foundry/bin:$PATH

# ===========================================
# Environment Selection
# ===========================================
# Options: local, sepolia, mainnet
BRIDGE_ENV=local

# ===========================================
# Chain Mode Selection
# ===========================================
# Options: devnet (recommended) | mainnet-fork (DEPRECATED)
# - devnet: Fresh genesis chain with controllable oracle prices
# - mainnet-fork: (DEPRECATED) Uses real mainnet state, requires 22GB+ LMDB
ZEPHYR_CHAIN_MODE=devnet

# ===========================================
# Path Configuration
# ===========================================
# Required repos
BRIDGE_REPO_PATH=${ROOT}/zephyr-bridge
ENGINE_REPO_PATH=${ROOT}/zephyr-bridge-engine
FOUNDRY_REPO_PATH=${ROOT}/zephyr-eth-foundry
ZEPHYR_REPO_PATH=${ROOT}/zephyr
ORCHESTRATION_PATH=${ROOT}/bridge-orchestration

# DEPRECATED: Only used in mainnet-fork mode
# In DEVNET mode, binaries are vendored in docker/zephyr/bin/ (via sync-zephyr-artifacts.sh)
# and data dirs are managed by Docker volumes.
# ZEPHYR_BIN_PATH=${ROOT}/zephyr/build/devnet/bin
# ZEPHYR_DATA_DIR=${ROOT}/zephyr-data
# ZEPHYR_WALLET_DIR=${ROOT}/zephyr-wallets
# ZEPHYR_SOURCE_LMDB=${HOME}/.zephyr/lmdb

# Snapshot paths
ZEPHYR_SNAPSHOT_DIR=${ORCHESTRATION_PATH}/snapshots/zephyr
ANVIL_SNAPSHOT_DIR=${ORCHESTRATION_PATH}/snapshots/anvil

# ===========================================
# EVM Configuration
# ===========================================
# ⚠ LOCAL DEV ONLY — All keys below are for Anvil (Chain ID 31337).
# NEVER use these on mainnet or with real funds. Generate your own for Sepolia/mainnet.
#
# Project mnemonic for Anvil and derived accounts
EVM_DEV_MNEMONIC=mask turtle fever floor spike immune glad meadow immense zero power forest hidden spot cat surround riot grocery adjust jar injury sand bomb venture

# Derived accounts (Index 0-5 from mnemonic above)
# Index 0: Deployer (deploys contracts, has admin role)
DEPLOYER_ADDRESS=0x8a87522ff7a811Af2E1EDA0FB3D99c8F5400Cf4B
DEPLOYER_PRIVATE_KEY=0x860875f05874e1ac2207f147a7a3e2a13d66520936cb598528e9104f2d5ec990

# Index 1: Bridge Signer (signs EIP-712 vouchers for claims)
BRIDGE_SIGNER_ADDRESS=0x8273E2C64415faCD40Db58181575B6f8f1337e22
BRIDGE_PK=0xdad112823784d70852482c06b20e6fae3f9a4b23fcb985930df6a57d17d31a27

# Index 2: Faucet/Minter (uses deployer key since MockERC20 mint is onlyOwner)
FAUCET_ADDRESS=0x8a87522ff7a811Af2E1EDA0FB3D99c8F5400Cf4B
FAUCET_PRIVATE_KEY=0x860875f05874e1ac2207f147a7a3e2a13d66520936cb598528e9104f2d5ec990

# Index 3-5: Test Users
TEST_USER_1_ADDRESS=0x1c491F2Ad3058d66A5924C8cc318F4Eb2733c9F7
TEST_USER_1_PK=0x46bb4b5b9b6298df5043e0b5f30713487849de04860e4f96088cf08342d80e27

TEST_USER_2_ADDRESS=0xb6b3aAC92b0634E2CAb4E211BF33bdF944F73B27
TEST_USER_2_PK=0xf2459ad48ec0548e7201d171539e10d79ab3a2dafd3ffb9fddc08043a83e1924

TEST_USER_3_ADDRESS=0x0FEDa12675f9a5bB820394FFb2A99AE31b0dE20f
TEST_USER_3_PK=0x88790762cffc6d78ce1f03adea6c23a2a896e77710399da371f0ac27d9d9146e

# RPC Endpoints (local Anvil)
EVM_RPC_HTTP=http://127.0.0.1:8545
EVM_RPC_WS=ws://127.0.0.1:8545
EVM_CHAIN_ID=31337

# Sepolia (when BRIDGE_ENV=sepolia)
EVM_RPC_HTTP_SEPOLIA=
EVM_RPC_WS_SEPOLIA=

# ===========================================
# Zephyr Configuration
# ===========================================
# Daemon RPC (DEVNET node1 on port 47767)
ZEPHYR_D_RPC_URL=http://127.0.0.1:47767

# Bridge wallet RPC (DEVNET wallet-test on port 48768)
ZEPH_WALLET_RPC_SERVER=127.0.0.1
ZEPH_WALLET_RPC_PORT=48768
ZEPH_RPC_TIMEOUT_MS=4000

# Mining configuration
# Fixed difficulty for local dev chain
# Mining difficulty modes (based on testing):
#   turbo=1   → ~1.5 sec/block (for rapid initial funding)
#   fast=10   → ~2.5 sec/block (for testing workflows)
#   normal=100 → ~2 sec/block (note: limited by oracle API latency)
# Note: Block time is bounded by oracle API latency (~2s minimum), so difficulty has diminishing returns
ZEPHYR_FIXED_DIFFICULTY=100
ZEPHYR_MINING_THREADS=1

# ===========================================
# Infrastructure (Docker)
# ===========================================
# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=6

# PostgreSQL
POSTGRES_USER=zephyr
POSTGRES_PASSWORD=zephyr
DATABASE_URL_BRIDGE=postgresql://zephyr:zephyr@localhost:5432/zephyrbridge_dev
DATABASE_URL_ENGINE=postgresql://zephyr:zephyr@localhost:5432/zephyr_bridge_arb

# ===========================================
# Application Settings
# ===========================================
# Bridge UI (port 7050)
NEXT_PUBLIC_BRIDGE_ENV=local
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ENABLE_DEV_CONTROLS=1

# Engine Dashboard (port 7000)
NEXT_PUBLIC_APP_NAME=Zephyr Arb Bot
NEXT_PUBLIC_BASE_URL=http://localhost:7000

# MEXC (engine uses paper trading by default)
MEXC_PAPER=true
MEXC_API_KEY=
MEXC_API_SECRET=

# ===========================================
# Process Management (Overmind)
# ===========================================
# --- DEPRECATED: Mainnet-fork Overmind formation ---
# This formation was for mainnet-fork mode (now removed)
# which runs Zephyr nodes and wallets natively via Overmind.
# In DEVNET mode, the Makefile uses Procfile.dev and Docker Compose handles
# Zephyr nodes/wallets. The formation below is only relevant for legacy mode.
#
# Formation: process=count (0 to disable)
# Available processes (mainnet-fork only):
#   zephyr-node1, zephyr-node2          - Zephyr daemon nodes
#   wallet-mining, wallet-bridge, wallet-exchange, wallet-testuser  - Wallet RPCs
#   bridge-web, bridge-watchers         - Bridge app
#   engine-web, engine-watchers         - Engine app
#   status-dashboard                    - Status dashboard (port 7100)

# OVERMIND_FORMATION=zephyr-node1=1,zephyr-node2=1,wallet-mining=1,wallet-bridge=1,wallet-exchange=1,wallet-testuser=1,bridge-web=1,bridge-watchers=1,engine-web=1,engine-watchers=1,status-dashboard=1
# --- END DEPRECATED ---

# Overmind settings
OVERMIND_SOCKET=${ORCHESTRATION_PATH}/.overmind.sock
OVERMIND_CAN_DIE=zephyr-node1,zephyr-node2

# ===========================================
# DEVNET Configuration
# ===========================================
# DEVNET build directory (built with --devnet flag)
ZEPHYR_DEVNET_BUILD_DIR=${ZEPHYR_REPO_PATH}/build/devnet

# DEVNET Ports (Docker Compose services)
DEVNET_ORACLE_PORT=5555
DEVNET_NODE1_P2P=47766
DEVNET_NODE1_RPC=47767
DEVNET_NODE1_ZMQ=47768
DEVNET_NODE2_P2P=47866
DEVNET_NODE2_RPC=47867
DEVNET_NODE2_ZMQ=47868
# Wallet RPC ports (must match docker/compose.dev.yml port mappings)
# Gov=48769, Miner=48767, Test=48768
DEVNET_WALLET_GOV_RPC=48769
DEVNET_WALLET_MINER_RPC=48767
DEVNET_WALLET_TEST_RPC=48768

# Fake Orderbook (tracks oracle price for DEVNET)
FAKE_ORDERBOOK_ENABLED=false
FAKE_ORDERBOOK_PORT=5556
FAKE_ORDERBOOK_SPREAD_BPS=50
FAKE_ORDERBOOK_DEPTH_LEVELS=20
