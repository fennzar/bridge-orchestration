# Zephyr Bridge Stack - Dev Hot-Reload Apps
#
# Infrastructure runs in Docker (Zephyr base + compose.bridge/engine/dev.yml).
# This Procfile only runs the native apps that benefit from hot-reload.
#
# Usage:
#   overmind start -D -f Procfile.dev
#   overmind connect bridge-web     # Attach to process (Ctrl-B D to detach)
#
# Env vars for Zephyr RPC URLs point to Docker containers on localhost.
# .env.local is sourced so NEXT_PUBLIC_* vars (PUBLIC_HOST-derived) reach Next.js.

bridge-web:      exec scripts/dev-proc.sh "cd $BRIDGE_REPO_PATH && set -a && source .env.local && set +a && rm -rf apps/web/.next && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm dev:web" >> bridge-web.log 2>&1
bridge-api:      exec scripts/dev-proc.sh "cd $BRIDGE_REPO_PATH && set -a && source .env.local && set +a && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_FAUCET_WALLET_PORT=48767 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm dev:api" >> bridge-api.log 2>&1
bridge-watchers: exec scripts/dev-proc.sh "cd $BRIDGE_REPO_PATH && set -a && source .env.local && set +a && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm dev:watchers" >> bridge-watchers.log 2>&1
engine-web:      exec scripts/dev-proc.sh "cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm --dir apps/web dev" >> engine-web.log 2>&1
engine-watchers: exec scripts/dev-proc.sh "cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm dev:watchers" >> engine-watchers.log 2>&1
engine-run:      exec scripts/dev-proc.sh "cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 BRIDGE_API_URL=http://127.0.0.1:7051 pnpm engine:run --mode devnet --strategies arb --interval 5000" >> engine-run.log 2>&1
dashboard:       exec scripts/dev-proc.sh "cd $ORCHESTRATION_PATH/status-dashboard && ZEPHYR_CHAIN_MODE=devnet pnpm dev"
rpc-filter:      node $ORCHESTRATION_PATH/rpc-filter.mjs
