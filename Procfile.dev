# Zephyr Bridge Stack - Dev Hot-Reload Apps
#
# Infrastructure runs in Docker (compose.base.yml + compose.dev.yml).
# This Procfile only runs the native apps that benefit from hot-reload.
#
# Usage:
#   overmind start -D -f Procfile.dev
#   overmind connect bridge-web     # Attach to process (Ctrl-B D to detach)
#
# Env vars for Zephyr RPC URLs point to Docker containers on localhost.

bridge-web:      cd $BRIDGE_REPO_PATH && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm dev:web
bridge-api:      cd $BRIDGE_REPO_PATH && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_FAUCET_WALLET_PORT=48767 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm dev:api
bridge-watchers: cd $BRIDGE_REPO_PATH && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm dev:watchers
engine-web:      cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm --dir apps/web dev
engine-watchers: cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm dev:watchers
dashboard:       cd $ORCHESTRATION_PATH/status-dashboard && ZEPHYR_CHAIN_MODE=devnet pnpm dev
