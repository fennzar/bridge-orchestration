# Zephyr Bridge Stack - Production Build Apps
#
# Infrastructure runs in Docker (compose.base.yml + compose.dev.yml).
# This Procfile runs apps from production builds (pnpm build -> pnpm start).
#
# Usage:
#   make testnet-v2-build              Build all apps
#   make testnet-v2                    Start stack with production builds
#
# Env vars for Zephyr RPC URLs point to Docker containers on localhost.

bridge-web:      exec scripts/dev-proc.sh "cd $BRIDGE_REPO_PATH && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm start:web"
bridge-api:      exec scripts/dev-proc.sh "cd $BRIDGE_REPO_PATH && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_FAUCET_WALLET_PORT=48767 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm start:api"
bridge-watchers: exec scripts/dev-proc.sh "cd $BRIDGE_REPO_PATH && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm run \"/^start:watcher:.*/\""
engine-web:      exec scripts/dev-proc.sh "cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm start:web"
engine-watchers: exec scripts/dev-proc.sh "cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm dev:watchers"
engine-run:      exec scripts/dev-proc.sh "cd $ENGINE_REPO_PATH && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 BRIDGE_API_URL=http://127.0.0.1:7051 pnpm engine:run --mode devnet --strategies arb --interval 5000"
dashboard:       exec scripts/dev-proc.sh "cd $ORCHESTRATION_PATH/status-dashboard && ZEPHYR_CHAIN_MODE=devnet pnpm start"
