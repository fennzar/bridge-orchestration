# Zephyr Bridge Stack - Production Build Apps
#
# Infrastructure runs in Docker (Zephyr base + compose.bridge/engine/dev.yml).
# This Procfile runs apps from production builds (pnpm build -> pnpm start).
#
# Usage:
#   make testnet-v2-build              Build all apps
#   make testnet-v2                    Start stack with production builds
#
# Env vars for Zephyr RPC URLs point to Docker containers on localhost.
# Unlike dev mode (tsx auto-loads .env.local), production mode needs explicit env sourcing.

bridge-web:      exec scripts/proc-wrapper.sh bridge-web "cd $BRIDGE_REPO_PATH && set -a && source .env.local && set +a && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm start:web"
bridge-api:      exec scripts/proc-wrapper.sh bridge-api "cd $BRIDGE_REPO_PATH && set -a && source .env.local && set +a && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_FAUCET_WALLET_PORT=48767 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm start:api"
bridge-watchers: exec scripts/proc-wrapper.sh bridge-watchers "cd $BRIDGE_REPO_PATH && set -a && source .env.local && set +a && ZEPH_WALLET_RPC_PORT=48770 ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 pnpm run --reporter=append-only \"/^start:watcher:.*/\""
engine-web:      exec scripts/proc-wrapper.sh engine-web "cd $ENGINE_REPO_PATH && set -a && source .env && set +a && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm --dir apps/web start"
engine-watchers: exec scripts/proc-wrapper.sh engine-watchers "cd $ENGINE_REPO_PATH && set -a && source .env && set +a && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 pnpm dev:watchers"
engine-run:      exec scripts/proc-wrapper.sh engine-run "cd $ENGINE_REPO_PATH && set -a && source .env && set +a && ZEPHYR_D_RPC_URL=http://127.0.0.1:47767 ZEPHYR_WALLET_RPC_URL=http://127.0.0.1:48771/json_rpc CEX_WALLET_RPC_URL=http://127.0.0.1:48772/json_rpc CEX_ADDRESS=$CEX_ADDRESS CEX_PK=$CEX_PK FAKE_ORDERBOOK_ENABLED=true FAKE_ORDERBOOK_PORT=5556 BRIDGE_API_URL=http://127.0.0.1:7051 pnpm engine:run --mode devnet --strategies arb --interval 5000"
dashboard:       exec scripts/proc-wrapper.sh dashboard "cd $ORCHESTRATION_PATH/status-dashboard && ZEPHYR_CHAIN_MODE=devnet pnpm start"
rpc-filter:      exec scripts/proc-wrapper.sh rpc-filter "node $ORCHESTRATION_PATH/rpc-filter.mjs"
