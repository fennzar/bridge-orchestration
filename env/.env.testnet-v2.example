# ===========================================
# Testnet V2 Environment Configuration (Anvil)
# ===========================================
# Copy to env/.env.testnet-v2 and fill in values.
# Used by compose.testnet-v2.yml app containers.

# ===========================================
# Environment
# ===========================================
BRIDGE_ENV=local
ZEPHYR_CHAIN_MODE=devnet

# ===========================================
# Domain (for Caddy TLS)
# ===========================================
DOMAIN=bridge.example.com

# ===========================================
# EVM Configuration (Anvil — Docker internal)
# ===========================================
EVM_RPC_HTTP=http://anvil:8545
EVM_RPC_WS=ws://anvil:8545
EVM_CHAIN_ID=31337

# Deployer / Bridge Signer (from make keygen)
DEPLOYER_ADDRESS=
DEPLOYER_PRIVATE_KEY=
BRIDGE_SIGNER_ADDRESS=
BRIDGE_PK=

# ===========================================
# Zephyr Configuration
# ===========================================
# Docker internal addresses (apps connect via Docker network)
ZEPHYR_D_RPC_URL=http://zephyr-node1:47767
ZEPH_WALLET_RPC_SERVER=wallet-test
ZEPH_WALLET_RPC_PORT=48768
ZEPH_RPC_TIMEOUT_MS=4000

# ===========================================
# Infrastructure (Docker internal)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=6

DATABASE_URL_BRIDGE=postgresql://zephyr:zephyr@postgres:5432/zephyrbridge_dev
DATABASE_URL_ENGINE=postgresql://zephyr:zephyr@postgres:5432/zephyr_bridge_arb

# ===========================================
# Application
# ===========================================
NEXT_PUBLIC_BRIDGE_ENV=local
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ENABLE_DEV_CONTROLS=0

NEXT_PUBLIC_APP_NAME=Zephyr Bridge Engine
NEXT_PUBLIC_BASE_URL=https://engine.bridge.example.com

# ===========================================
# Engine
# ===========================================
FAKE_ORDERBOOK_ENABLED=true
FAKE_ORDERBOOK_PORT=5556
MEXC_PAPER=true
MEXC_API_KEY=
MEXC_API_SECRET=

# ===========================================
# Blockscout (override defaults from compose.blockscout.yml)
# ===========================================
BLOCKSCOUT_API_HOST=explorer.bridge.example.com
BLOCKSCOUT_API_PROTOCOL=https
BLOCKSCOUT_PORT=4000
